{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",

    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,

    "removeComments": true,

    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "strict": false,

    "moduleResolution": "node",
   
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}