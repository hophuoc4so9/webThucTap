{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "ES2021",
    "lib": ["ES2021"],

    "declaration": true,
    "outDir": "./dist",
    "incremental": true,

    "paths": {
  "@/*": ["./src/*"]
    },

    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": false
  }
}